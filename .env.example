# Vision AI - optional env overrides (docker-compose or export before run)
# PORT=5000
# Use raw stream resolution as inference input (e.g. 2688x1520, 1920x1080). Default 1. Set 0 to use fixed VISION_INFERENCE_IMGSZ.
# VISION_USE_NATIVE_RESOLUTION=1
# When native resolution is 0, inference uses this size (480/640/720). Ignored when VISION_USE_NATIVE_RESOLUTION=1.
# VISION_INFERENCE_IMGSZ=720
# VISION_TARGET_FPS=9
# VISION_MICRO_BATCH=8
# VISION_USE_FP16=1
# VISION_USE_TENSORRT=1
# VISION_CALLBACK_POOL_WORKERS=12
# IP camera discovery subnet (Quick Add / network scan). Example: 172.30.121.0/24
# VISION_CAMERA_SCAN_SUBNET=172.30.121.0/24
# Qwen2.5-VL local folder (must be qwen2_5_vl, not Qwen3.5)
# VISION_QWEN25VL_LOCAL_PATH=
